// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(DEALER)
  isApproved   Boolean  @default(false)
  emailVerified Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  ADMIN
  DEALER
}

model Brand {
  id             String   @id @default(uuid())
  name           String
  logoUrl        String
  description_tr String?
  description_en String?
  url            String?
  products       Product[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id             String     @id @default(uuid())
  name_en        String
  name_tr        String?
  description_en String?
  description_tr String?
  imageUrl       String?
  
  // Self-relation for sub-categories
  parentId    String?
  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")

  products    Product[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Product {
  id             String         @id @default(uuid())
  name_en        String
  name_tr        String?
  description_en String         @db.Text
  description_tr String?        @db.Text
  technicalSpecs Json?
  
  brandId        String
  brand          Brand          @relation(fields: [brandId], references: [id])
  
  categoryId     String
  category       Category       @relation(fields: [categoryId], references: [id])
  
  isFeatured     Boolean        @default(false)
  
  images         ProductImage[]
  documents      Document[]
  
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model ProductImage {
  id        String   @id @default(uuid())
  url       String
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id        String   @id @default(uuid())
  title     String
  type      String   // e.g., "PDF", "EXCEL", "WORD"
  url       String
  isPublic  Boolean  @default(true)
  
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id             String   @id @default(uuid())
  aboutText_en   String   @db.Text
  aboutText_tr   String?  @db.Text
  phone          String?
  email          String?
  address        String?
  
  heroTitle_tr   String?  @db.Text
  heroTitle_en   String?  @db.Text
  heroDesc_tr    String?  @db.Text
  heroDesc_en    String?  @db.Text
  heroImageUrl   String?
  heroBgImageUrl String?

  refNotice_tr   String?  @db.Text
  refNotice_en   String?  @db.Text

  updatedAt      DateTime @updatedAt
}

model Reference {
  id          String   @id @default(uuid())
  name_tr     String
  name_en     String?
  sector_tr   String?
  sector_en   String?
  logoUrl     String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id             String   @id @default(uuid())
  title_tr       String
  title_en       String?
  location       String?
  date           DateTime
  imageUrl       String?
  description_tr String?  @db.Text
  description_en String?  @db.Text
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

